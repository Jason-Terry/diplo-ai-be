# ── LLM provider keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Storage ───────────────────────────────────────────────────────────────────
# Local Mongo via podman (poe db:up). Leave blank to use the file-backed log.
MONGODB_URI=mongodb://localhost:27017/diploai

# Remote dev Mongo on Railway. Used by `poe dev-remote` to point at hosted DB.
RAILWAY_MONGODB_URI=

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated FE origins allowed to send credentials. Wildcard "*" is
# rejected when cookies are in play. Local dev defaults to localhost:8420 when
# this var is unset. Production must list every FE origin explicitly.
# CORS_ALLOWED_ORIGINS=https://www.metisdolos.com,https://metisdolos.com

# ── Auth ─────────────────────────────────────────────────────────────────────
# Required in prod. Long random string:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=change-me-in-prod
# JWT_EXPIRES_SECONDS=604800       # default 7 days

# Cookie attributes
# COOKIE_DOMAIN=.metisdolos.com    # set in prod so the cookie travels to api. and www.
# COOKIE_INSECURE=1                # dev only — lets cookies work over http://localhost

# ── Email verification (Resend) ──────────────────────────────────────────────
# Unset → the BE logs the magic link to stderr instead of sending mail.
# RESEND_API_KEY=re_...
# EMAIL_FROM=MetisDolos <noreply@metisdolos.com>

# ── Public URLs (used by the email-verify link) ──────────────────────────────
PUBLIC_BE_URL=http://localhost:8421
PUBLIC_FE_URL=http://localhost:8420
