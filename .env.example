# ── LLM provider keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key-here
OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Storage ───────────────────────────────────────────────────────────────────
# Local Mongo via podman (poe db:up). Leave blank to use the file-backed log.
MONGODB_URI=mongodb://localhost:27017/diploai

# Remote dev Mongo on Railway. Used by `poe dev-remote` to point at hosted DB.
RAILWAY_MONGODB_URI=

# ── App ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for the FE. Leave as "*" in local dev.
# Production: set to the deployed FE URL, e.g. https://diplo-ai-fe.up.railway.app
CORS_ALLOWED_ORIGINS=*
